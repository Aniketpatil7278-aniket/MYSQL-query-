2. One-to-Many (1:N)
One record in the parent table can have many related records in the child table.

Example
One customer can place many orders.

Customer
+-------------+
| customer_id |
| name        |
+-------------+
      |
      | 1 : N
      |
Orders
+------------+
| order_id   |
| customer_id|
| product    |
+------------+

CREATE TABLE Customer (
    customer_id INT PRIMARY KEY,
    customer_name VARCHAR(50)
);

INSERT INTO Customer VALUES (1, 'Aniket');
INSERT INTO Customer VALUES (2, 'Rahul');
INSERT INTO Customer VALUES (3, 'Priya');
INSERT INTO Customer VALUES (4, 'Amit');
INSERT INTO Customer VALUES (5, 'Sneha');

CREATE TABLE Orders (
    order_id INT PRIMARY KEY,
    product VARCHAR(50),
    customer_id INT,
    FOREIGN KEY (customer_id) REFERENCES Customer(customer_id)
);

INSERT INTO Orders VALUES (101, 'Laptop', 1);
INSERT INTO Orders VALUES (102, 'Mouse', 1);
INSERT INTO Orders VALUES (103, 'Keyboard', 2);
INSERT INTO Orders VALUES (104, 'Monitor', 3);
INSERT INTO Orders VALUES (105, 'Printer', 5);


SELECT * FROM Customer;
